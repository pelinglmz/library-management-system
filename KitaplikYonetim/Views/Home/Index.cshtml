@model KitaplikYonetim.Models.ViewModels.DashboardVM

<div class="container mt-5">
    @* Üst İstatistik Kartları *@
    <div class="row text-center">
        <div class="col-md-3">
            <div class="card border-primary mb-3 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-primary">Toplam Kitap</h4>
                    <p class="card-text h2">@Model.BookCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success mb-3 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-success">Yazar Sayısı</h4>
                    <p class="card-text h2">@Model.AuthorCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info mb-3 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-info">Kategori</h4>
                    <p class="card-text h2">@Model.CategoryCount</p>
                </div>
            </div>
        </div>
        @* Yayınevi sayısını da ekledik ki 4 tablo şartı Dashboard'da görünsün *@
        <div class="col-md-3">
            <div class="card border-warning mb-3 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-warning">Yayınevi</h4>
                    <p class="card-text h2">@Model.PublisherCount</p>
                </div>
            </div>
        </div>
    </div>

    @* Son Eklenen Kitaplar Tablosu *@
    <div class="mt-5">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
            <h3><i class="bi bi-clock-history"></i> Son Eklenen Kitaplar</h3>
            <a asp-controller="Book" asp-action="Index" class="btn btn-outline-secondary btn-sm">Tümünü Gör</a>
        </div>

        <table class="table table-hover mt-3 shadow-sm rounded overflow-hidden">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">Resim</th>
                    <th>Kitap Adı</th>
                    <th>Kategori</th>
                    <th>Yazar</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentBooks != null && Model.RecentBooks.Any())
                {
                    foreach (var item in Model.RecentBooks)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath" width="60" height="85" class="rounded shadow-sm" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light text-center rounded shadow-sm" style="width: 60px; height: 85px; line-height: 85px;">
                                        <i class="bi bi-book text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="align-middle fw-bold">@item.Title</td>
                            <td class="align-middle">
                                @* Eager Loading (Include) yapıldıysa burası artık boş gelmez *@
                                <span class="badge bg-light text-dark border">
                                    @(item.Category?.Name ?? "Kategori Belirtilmemiş")
                                </span>
                            </td>
                            <td class="align-middle text-muted">
                                @(item.Author?.FullName ?? "Yazar Belirtilmemiş")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">Henüz kitap eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>